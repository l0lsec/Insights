# Insights Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Required
# ===================

# OpenAI API key for summarization, action item extraction, and thumbnail generation (DALL-E 3)
OPENAI_API_KEY=your-openai-api-key-here

# Thumbnails: uses OpenAI Images API (gpt-image-1) with OPENAI_API_KEY by default.
# Optional: set only if you use a custom CLI that accepts the JSON payload on argv (legacy).
# ASI_GENERATE_IMAGE=/full/path/to/your-thumbnail-cli

# ===================
# Optional
# ===================

# OpenAI model to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Cloud LLM provider for text/vision generation: "openai" (default) or "anthropic".
# Whisper transcription and thumbnail image generation always use OpenAI (Anthropic
# has no equivalent), so keep OPENAI_API_KEY set for those even when using Anthropic.
# LLM_PROVIDER=openai

# Anthropic (Claude) API key. Required only when LLM_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use when LLM_PROVIDER=anthropic (default: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Ollama for local AI (optional, for free post generation)
# Install from https://ollama.com then run: ollama pull llama3.2-vision && ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_VISION_MODEL=llama3.2-vision
# OLLAMA_TEXT_MODEL=llama3.2

# Usage meters (/usage page): estimated cost per AI call. Token counts are exact;
# dollar cost is estimated from the rates below (defaults reflect list prices at the
# time of writing). Override any to match your OpenAI plan. Chat rates are USD per
# 1,000,000 tokens (input / output); Whisper is USD per minute; image is USD per image.
# USAGE_PRICE_GPT_4O_IN=2.50
# USAGE_PRICE_GPT_4O_OUT=10.00
# USAGE_PRICE_GPT_4O_MINI_IN=0.15
# USAGE_PRICE_GPT_4O_MINI_OUT=0.60
# USAGE_PRICE_GPT_41_IN=2.00
# USAGE_PRICE_GPT_41_OUT=8.00
# USAGE_PRICE_GPT_41_MINI_IN=0.40
# USAGE_PRICE_GPT_41_MINI_OUT=1.60
# USAGE_PRICE_DEFAULT_IN=2.50
# USAGE_PRICE_DEFAULT_OUT=10.00
# USAGE_WHISPER_PER_MIN=0.006
# USAGE_PRICE_IMAGE=0.19
# Anthropic (Claude) chat rates, USD per 1,000,000 tokens (input / output),
# matched by model-name prefix. Used when LLM_PROVIDER=anthropic.
# USAGE_PRICE_CLAUDE_OPUS_IN=5.00
# USAGE_PRICE_CLAUDE_OPUS_OUT=25.00
# USAGE_PRICE_CLAUDE_SONNET_IN=3.00
# USAGE_PRICE_CLAUDE_SONNET_OUT=15.00
# USAGE_PRICE_CLAUDE_HAIKU_IN=1.00
# USAGE_PRICE_CLAUDE_HAIKU_OUT=5.00
# USAGE_PRICE_CLAUDE_DEFAULT_IN=5.00
# USAGE_PRICE_CLAUDE_DEFAULT_OUT=25.00

# Port for the Flask web server (default: 5001)
# PORT=5001

# ===================
# JIRA Integration (Optional)
# ===================
# Required if you want to create JIRA tickets from action items

# Your JIRA Cloud instance URL (e.g., https://yourcompany.atlassian.net)
# JIRA_BASE_URL=https://example.atlassian.net

# Email associated with your JIRA account
# JIRA_EMAIL=your-email@example.com

# JIRA API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
# JIRA_API_TOKEN=your-jira-api-token

# Project key where issues will be created
# JIRA_PROJECT_KEY=PROJ

# ===================
# LinkedIn Integration (Optional)
# ===================
# Required to post to LinkedIn. Create an app at https://www.linkedin.com/developers/apps
# Enable "Share on LinkedIn" product and (optionally) "Sign In with LinkedIn using OpenID Connect"

# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_REDIRECT_URI=http://localhost:5001/linkedin/callback

# ===================
# Threads Integration (Optional)
# ===================
# Required to post to Threads. Create a Meta app at https://developers.facebook.com/apps/
# Add the "Threads API" product and configure a Threads tester (see Configure page for details)

# THREADS_APP_ID=your_threads_app_id
# THREADS_APP_SECRET=your_threads_app_secret
# THREADS_REDIRECT_URI=https://localhost:5001/threads/callback

# ===================
# Facebook Integration (Optional)
# ===================
# Required to post to Facebook Pages/Groups. Uses the same Meta Developer Portal as Threads.
# Create an app at https://developers.facebook.com/apps/ and add "Facebook Login for Business"
# Required permissions: pages_manage_posts, pages_read_engagement
# Optional: publish_to_groups (requires App Review for production; works in dev mode for admins)

# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret
# FACEBOOK_REDIRECT_URI=http://localhost:5001/facebook/callback

# ===================
# X / Twitter Integration (Optional)
# ===================
# Required to post to X/Twitter. Create an app at https://developer.x.com
# Enable OAuth 2.0 with PKCE, set callback URL to your redirect URI.
# Pay-per-use: $0.01/post, includes media upload.

# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret
# TWITTER_REDIRECT_URI=http://localhost:5001/twitter/callback

# ===================
# Cloudinary (Optional)
# ===================
# Required for image uploads that work with Threads and other external platforms
# Sign up free at https://cloudinary.com

# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ===================
# Stock Images (Optional - all free)
# ===================
# Configure at least one to enable auto-image generation for posts
# All services are 100% free with generous rate limits

# Unsplash - Best quality, 50 req/hour
# Sign up at https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels - Great quality, 200 req/hour  
# Sign up at https://www.pexels.com/api/
# PEXELS_API_KEY=your_pexels_api_key

# Pixabay - Good quality, 5000 req/hour
# Sign up at https://pixabay.com/api/docs/
# PIXABAY_API_KEY=your_pixabay_api_key

# ============================================================
# Content Agent (agentic content preparation)
# ============================================================
# Master switch for the recurring-brief background worker.
# On-demand "Run now" still works even if this is false.
# CONTENT_AGENT_ENABLED=true
# How often (seconds) the worker checks for due briefs.
# CONTENT_AGENT_TICK_SECONDS=60
# Optional cheaper model for the agent's research LLM calls (query planning /
# brief synthesis). Defaults to OPENAI_MODEL when unset.
# CONTENT_AGENT_MODEL=gpt-4o-mini

# ---- Web search provider (research procurement) ----
# auto = Tavily if TAVILY_API_KEY set, else Brave if BRAVE_SEARCH_API_KEY set,
#        else OpenAI native web search (uses OPENAI_API_KEY), else none.
# WEB_SEARCH_PROVIDER=auto
# Tavily (recommended: clean, agent-friendly results). https://tavily.com
# TAVILY_API_KEY=
# Brave Search API (optional alternative). https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=
# Optional: override the OpenAI model used for native web search.
# OPENAI_SEARCH_MODEL=gpt-4o
# Results requested per search query.
# WEB_SEARCH_MAX_RESULTS=5

# ---- Research pipeline caps (bound cost + latency for unattended runs) ----
# RESEARCH_MAX_SEARCHES=6
# RESEARCH_MAX_FETCHES=15
# RESEARCH_MAX_ITEMS=12
# RESEARCH_QUERY_COUNT=4
# RESEARCH_PER_DOMAIN_CAP=2
# RESEARCH_MAX_TEXT_CHARS=8000
# Reuse cached url_sources content newer than this without re-fetching.
# RESEARCH_SOURCE_TTL_DAYS=14

# ---- External web-search cost estimates (USD per call), shown on /usage ----
# USAGE_PRICE_SEARCH_TAVILY=0.008
# USAGE_PRICE_SEARCH_BRAVE=0.005
